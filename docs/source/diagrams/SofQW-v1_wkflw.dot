digraph  {
  $global_style

  subgraph params {
    $param_style
    Method
    InputWorkspace
    QAxisBinning
    EMode
    EFixed
  }

  subgraph algorithms {
    $algorithm_style
    SofQW
    SofQWNormalisedPolygon
  }

  Method -> SofQW

  InputWorkspace -> SofQW
  QAxisBinning -> SofQW
  EMode -> SofQW
  EFixed -> SofQW

  SofQW -> SofQWNormalisedPolygon [label="Method=NormalisedPolygon"]

}
